  "capabilities": {
    "agentOrchestration": "Copilot CLI agent definitions with handoffs and body instructions",
    "skillLibrary": "64 production code skills across 10 categories",
    "instructionFiles": "7 auto-applied instruction files for language-specific patterns",
    "promptTemplates": "12 reusable prompt templates for common workflows",
    "cliUtilities": "PowerShell/Bash scripts for issue tracking, loop management, and workflow",
    "iterativeLoop": "Quality loop enforcement via CLI hard gate (Layer 3)"
  },
  "limitations": {
    "noRunSubagent": "Copilot CLI does not support runSubagent -- agents run standalone, no agent chaining",
    "noMode1": "Mode 1 (Agent X hub orchestration) is not available -- agents operate independently",
    "noSidebar": "No VS Code sidebar views -- use CLI commands directly",
    "layerCoverage": "Quality enforcement: Layer 2 (body instructions) + Layer 3 (CLI gate). Layer 1 (Copilot native loop) depends on CLI version."
  },
  "install": {
    "powershell": "pwsh packs/agentx-copilot-cli/install.ps1",
    "bash": "bash packs/agentx-copilot-cli/install.sh",
    "note": "Installer copies agents, skills, instructions, and prompts into the target workspace .github/ directory."
