    "configuration": {
      "title": "AgentX",
      "properties": {
        "agentx.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh agent status."
        },
        "agentx.shell": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "pwsh",
            "bash"
          ],
          "description": "Shell to use for AgentX CLI commands."
        },
        "agentx.rootPath": {
          "type": "string",
          "default": "",
          "description": "Explicit path to the AgentX project root (folder containing AGENTS.md and .agentx/). Leave empty for auto-detection. Useful when AgentX is initialized in a subfolder or non-first workspace folder."
        },
        "agentx.searchDepth": {
          "type": "number",
          "default": 2,
          "minimum": 0,
          "maximum": 5,
          "description": "How many subfolder levels to search when auto-detecting the AgentX root. Set to 0 to only check workspace folder roots."
        },
        "agentx.skipStartupCheck": {
          "type": "boolean",
          "default": false,
          "description": "Skip the automatic environment health check on extension activation. You can always run it manually via AgentX: Check Environment."
        },
        "agentx.skipUpdateCheck": {
          "type": "boolean",
          "default": false,
          "description": "Skip the automatic version check that detects outdated framework files on extension activation. When enabled, you will not be prompted to update."
        },
        "agentx.companionDismissed": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "List of companion extension IDs for which the install prompt has been permanently dismissed."
        }
      }
    }
