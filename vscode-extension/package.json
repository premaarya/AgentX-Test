{
  "name": "agentx",
  "displayName": "AgentX - Multi-Agent Orchestration",
  "description": "AI-powered multi-agent orchestration framework for GitHub Copilot. Coordinate PM, UX, Architect, Data Scientist, Engineer, Reviewer, DevOps, Tester, Power BI Analyst, and Consulting Research agents in a structured software development workflow.",
  "version": "8.4.21",
  "publisher": "jnPiyush",
  "extensionKind": [
    "workspace",
    "ui"
  ],
  "author": {
    "name": "Piyush Jain"
  },
  "icon": "resources/icon.png",
  "license": "Apache-2.0",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jnPiyush/AgentX"
  },
  "bugs": {
    "url": "https://github.com/jnPiyush/AgentX/issues"
  },
  "homepage": "https://github.com/jnPiyush/AgentX#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Other",
    "SCM Providers"
  ],
  "keywords": [
    "copilot",
    "ai-agents",
    "multi-agent",
    "orchestration",
    "workflow",
    "product-manager",
    "architect",
    "engineer",
    "code-review",
    "agentx"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onChatParticipant:agentx.chat"
  ],
