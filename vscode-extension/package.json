    "configuration": {
      "title": "AgentX",
      "properties": {
        "agentx.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh agent status."
        },
        "agentx.shell": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "pwsh",
            "bash"
          ],
          "description": "Shell to use for AgentX CLI commands."
        },
        "agentx.rootPath": {
          "type": "string",
          "default": "",
          "description": "Explicit path to the AgentX project root (folder containing AGENTS.md and .agentx/). Leave empty for auto-detection. Useful when AgentX is initialized in a subfolder or non-first workspace folder."
        },
        "agentx.searchDepth": {
          "type": "number",
          "default": 2,
          "minimum": 0,
          "maximum": 5,
          "description": "How many subfolder levels to search when auto-detecting the AgentX root. Set to 0 to only check workspace folder roots."
        },
        "agentx.skipStartupCheck": {
          "type": "boolean",
          "default": false,
          "description": "Skip the automatic environment health check on extension activation. You can always run it manually via AgentX: Check Environment."
        },
        "agentx.skipUpdateCheck": {
          "type": "boolean",
          "default": false,
          "description": "Skip the automatic version check that detects outdated framework files on extension activation. When enabled, you will not be prompted to update."
        },
        "agentx.companionDismissed": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "List of companion extension IDs for which the install prompt has been permanently dismissed."
        }
      }
    }
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('out',{recursive:true,force:true})\"",
    "copy:assets": "node scripts/copy-assets.js",
    "prepare:chat": "node scripts/prepare-chat-contributions.js",
    "vscode:prepublish": "npm run prepare:chat && npm run copy:assets && npm run compile",
    "compile": "npm run clean && tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "npm run compile && mocha",
    "test:coverage": "npm run compile && nyc mocha",
    "coverage:html": "npm run test:coverage && nyc report --reporter=html",
    "coverage:lcov": "npm run test:coverage && nyc report --reporter=lcov",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@istanbuljs/nyc-config-typescript": "^1.0.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.11.0",
    "@types/sinon": "^21.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/vsce": "^3.0.0",
    "eslint": "^8.56.0",
    "mocha": "^11.3.0",
    "nyc": "^15.1.0",
    "sinon": "^21.0.1",
    "typescript": "^5.3.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.3"
  },
  "nyc": {
    "extends": "@istanbuljs/nyc-config-typescript",
    "all": true,
    "check-coverage": true,
    "lines": 80,
    "statements": 80,
    "functions": 80,
    "branches": 80,
    "include": [
      "src/**/*.ts"
    ],
    "exclude": [
      "src/test/**",
      "src/**/*.test.ts",
      "src/**/mocks/**",
      "src/extension.ts",
      "out/**"
    ],
    "reporter": [
      "text",
      "html",
      "lcov"
    ],
    "report-dir": "coverage"
  }
}
