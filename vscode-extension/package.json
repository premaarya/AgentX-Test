    "type": "git",
    "url": "https://github.com/jnPiyush/AgentX"
  },
  "bugs": {
    "url": "https://github.com/jnPiyush/AgentX/issues"
  },
  "homepage": "https://github.com/jnPiyush/AgentX#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Other",
    "SCM Providers"
