  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "agentx.initialize",
        "title": "Add Integration",
        "category": "AgentX",
        "icon": "$(plug)"
      },
      {
        "command": "agentx.showStatus",
        "title": "Show Agent Status",
        "category": "AgentX",
        "icon": "$(info)"
      },
      {
        "command": "agentx.runWorkflow",
        "title": "Run Workflow",
        "category": "AgentX",
        "icon": "$(play)"
      },
      {
        "command": "agentx.checkDeps",
        "title": "Check Dependencies",
        "category": "AgentX",
        "icon": "$(git-merge)"
      },
      {
        "command": "agentx.generateDigest",
        "title": "Generate Weekly Digest",
        "category": "AgentX",
        "icon": "$(notebook)"
      },
      {
        "command": "agentx.refresh",
        "title": "Refresh",
        "category": "AgentX",
        "icon": "$(refresh)"
      },
      {
        "command": "agentx.showIssue",
        "title": "Show Issue Detail",
        "category": "AgentX",
        "icon": "$(eye)"
      },
      {
        "command": "agentx.checkEnvironment",
        "title": "Check Environment",
        "category": "AgentX",
        "icon": "$(beaker)"
      },
      {
        "command": "agentx.loop",
        "title": "Iterative Loop",
        "category": "AgentX",
        "icon": "$(sync)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agentx-sidebar",
          "title": "AgentX",
          "icon": "resources/agentx-icon.svg"
        }
      ]
    },
    "views": {
      "agentx-sidebar": [
        {
          "id": "agentx-agents",
          "name": "Agents",
          "icon": "$(organization)",
          "contextualTitle": "AgentX Agents"
        },
        {
          "id": "agentx-templates",
          "name": "Templates",
          "icon": "$(file-text)",
          "contextualTitle": "AgentX Templates"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "agentx-agents",
        "contents": "AgentX is ready to use.\n\nAdd integrations for GitHub or Azure DevOps:\n[Add Integration](command:agentx.initialize)\n\n[Learn more](https://github.com/jnPiyush/AgentX)",
        "when": "!agentx.githubConnected && !agentx.adoConnected"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "agentx.refresh",
          "when": "view == agentx-agents || view == agentx-templates",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "agentx.showIssue",
          "when": "false",
          "group": "inline"
        }
      ],
      "commandPalette": [
        {
          "command": "agentx.showIssue",
          "when": "false"
        },
        {
          "command": "agentx.refresh"
        },
        {
          "command": "agentx.showStatus"
        },
        {
          "command": "agentx.runWorkflow"
        },
        {
          "command": "agentx.checkDeps"
        },
        {
          "command": "agentx.generateDigest"
        }
      ]
    },
