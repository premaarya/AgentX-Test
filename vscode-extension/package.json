      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "agentx.refresh",
          "when": "view == agentx-work || view == agentx-status || view == agentx-skills",
          "group": "navigation"
        },
        {
          "command": "agentx.addSkill",
          "when": "view == agentx-skills",
          "group": "navigation"
        },
        {
          "command": "agentx.hireAgent",
          "when": "view == agentx-work",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "agentx.showIssue",
          "when": "false",
          "group": "inline"
