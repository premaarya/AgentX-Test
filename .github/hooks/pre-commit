#!/usr/bin/env bash
# Pre-commit hook: Security and quality checks ONLY
# Workflow validation is handled by pre-handoff validation (.github/scripts/validate-handoff.sh)
# Issue reference validation is handled by commit-msg hook

echo "[INFO] Running pre-commit checks..."

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

FAILED=0

echo ""
echo -e "${BLUE}-------------------------------------------------------${NC}"
echo -e "${BLUE}Security & Quality Checks${NC}"
echo -e "${BLUE}-------------------------------------------------------${NC}"
echo ""

# Check 1: No secrets in staged files (exclude .md docs - they contain example patterns)
echo -n "Checking for secrets... "
if git diff --cached --name-only | grep -v '\.md$' | xargs grep -E '(password|api[_-]?key|secret|token|private[_-]?key)\s*=\s*["\x27][^"\x27]+["\x27]' -i 2>/dev/null; then
 echo -e "${RED}[FAIL] FAILED${NC}"
 echo " Found potential secrets in staged files!"
 echo " Use environment variables instead."
 FAILED=1
else
 echo -e "${GREEN}[PASS] PASSED${NC}"
fi

# Check 2: No large files (>1MB)
echo -n "Checking file sizes... "
LARGE_FILES=$(git diff --cached --name-only | xargs ls -l 2>/dev/null | awk '$5 > 1048576 {print $9}')
if [ -n "$LARGE_FILES" ]; then
 echo -e "${YELLOW}[WARN] WARNING${NC}"
 echo " Large files detected (>1MB):"
 echo "$LARGE_FILES" | sed 's/^/ /'
else
 echo -e "${GREEN}[PASS] PASSED${NC}"
fi

# Check 3: Warn on direct master/main commits
BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)
if [ "$BRANCH" = "main" ] || [ "$BRANCH" = "master" ]; then
 echo -e "${YELLOW}[WARN] WARNING: Committing directly to $BRANCH${NC}"
fi

# Check 4: C# formatting (if dotnet available)
if command -v dotnet &> /dev/null; then
 CS_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.cs$')
 if [ -n "$CS_FILES" ]; then
 echo -n "Checking C# formatting... "
 if dotnet format --verify-no-changes --include $CS_FILES &>/dev/null; then
 echo -e "${GREEN}[PASS] PASSED${NC}"
 else
 echo -e "${YELLOW}[WARN] Auto-formatting${NC}"
 dotnet format --include $CS_FILES
 echo "$CS_FILES" | xargs git add
 fi
 fi
fi

# Check 5: Python formatting (if black available)
if command -v black &> /dev/null; then
 PY_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$')
 if [ -n "$PY_FILES" ]; then
 echo -n "Checking Python formatting... "
 if black --check $PY_FILES &>/dev/null; then
 echo -e "${GREEN}[PASS] PASSED${NC}"
 else
 echo -e "${YELLOW}[WARN] Auto-formatting${NC}"
 black $PY_FILES
 echo "$PY_FILES" | xargs git add
 fi
 fi
fi

# Check 6: SQL injection patterns
echo -n "Checking for SQL injection risks... "
if git diff --cached | grep -E '\+.*\b(ExecuteRaw|FromSqlRaw|SqlQuery).*\+' | grep -v 'parameterized' | grep -v '@' &>/dev/null; then
 echo -e "${YELLOW}[WARN] WARNING: Potential SQL injection${NC}"
else
 echo -e "${GREEN}[PASS] PASSED${NC}"
fi

# Check 7: Command allowlist validation (only check newly created code files)
echo -n "Checking for blocked commands... "
BLOCKED_COMMANDS=("rm -rf" "git reset --hard" "git push --force" "DROP DATABASE" "DROP TABLE" "TRUNCATE" "format c:" "del /s" "rmdir /s")
BLOCKED_FOUND=0
NEW_CODE_FILES=$(git diff --cached --name-only --diff-filter=A | grep -v '\\.md$' | grep -v '\\.test\\.ts$' | grep -v '\\.test\\.js$' | grep -v '\\.spec\\.ts$' | grep -v '\\.spec\\.js$' | grep -v 'commandValidator')

if [ -n "$NEW_CODE_FILES" ]; then
 for cmd in "${BLOCKED_COMMANDS[@]}"; do
  if echo "$NEW_CODE_FILES" | xargs grep -F "$cmd" 2>/dev/null; then
   echo -e "${RED}[FAIL] BLOCKED COMMAND: $cmd${NC}"
   BLOCKED_FOUND=1
  fi
 done
fi

if [ $BLOCKED_FOUND -eq 0 ]; then
 echo -e "${GREEN}[PASS] PASSED${NC}"
else
 echo -e "${RED}[FAIL] Blocked destructive command found${NC}"
 echo " Review .github/security/allowed-commands.json for allowed operations"
 FAILED=1
fi

# Summary
echo ""

# ---------------------------------------------------------------
# Check 8: Quality loop enforcement
# Block commits when engineer has an active/incomplete loop.
# Only blocks when loop-state.json exists and loop is NOT complete.
# ---------------------------------------------------------------
LOOP_STATE=".agentx/state/loop-state.json"
if [ -f "$LOOP_STATE" ]; then
  LOOP_ACTIVE=$(grep -o '"active":\s*true' "$LOOP_STATE" 2>/dev/null)
  LOOP_STATUS=$(grep -o '"status":\s*"[^"]*"' "$LOOP_STATE" 2>/dev/null | head -1 | sed 's/"status":\s*"//' | sed 's/"//')

  if [ -n "$LOOP_ACTIVE" ]; then
    echo -e "${RED}[FAIL] Quality loop still ACTIVE (iteration in progress)${NC}"
    echo "  Complete the loop before committing: agentx loop complete -s <summary>"
    echo "  Or cancel if needed: agentx loop cancel"
    FAILED=1
  elif [ "$LOOP_STATUS" = "cancelled" ]; then
    echo -e "${YELLOW}[WARN] Quality loop was cancelled (does not satisfy quality gate)${NC}"
    echo "  Start and complete a new loop for handoff eligibility."
  elif [ "$LOOP_STATUS" = "complete" ]; then
    echo -e "${GREEN}[PASS] Quality loop completed${NC}"
  fi
fi

# ---------------------------------------------------------------
# Check 9: Review document requires completed loop
# Block commits of review artifacts when no completed loop exists.
# Catches agents that skip loop start entirely.
# ---------------------------------------------------------------
REVIEW_DOCS=$(git diff --cached --name-only | grep '^docs/artifacts/reviews/.*\.md$')
if [ -n "$REVIEW_DOCS" ]; then
  LOOP_COMPLETE=0
  if [ -f "$LOOP_STATE" ]; then
    LOOP_STATUS_CHECK=$(grep -o '"status":[[:space:]]*"[^"]*"' "$LOOP_STATE" 2>/dev/null | head -1 | sed 's/"status":[[:space:]]*"//' | sed 's/"//')
    if [ "$LOOP_STATUS_CHECK" = "complete" ]; then
      LOOP_COMPLETE=1
    fi
  fi
  if [ $LOOP_COMPLETE -eq 0 ]; then
    echo -e "${RED}[FAIL] Review document staged but quality loop not completed${NC}"
    echo "  Review agents MUST run the quality loop before committing:"
    echo "    agentx loop start -p \"Reviewing: <description>\""
    echo "    ... (verify, self-review, iterate)"
    echo "    agentx loop complete -s \"All quality gates passed\""
    FAILED=1
  else
    echo -e "${GREEN}[PASS] Review document has completed quality loop${NC}"
  fi
fi

# ---------------------------------------------------------------
# Check 10: Learning capture file structure validation
# Validates LEARNING-*.md files have required sections.
# Catches incomplete compound capture artifacts before they land.
# ---------------------------------------------------------------
LEARNING_FILES=$(git diff --cached --name-only | grep '^docs/artifacts/learnings/LEARNING-.*\.md$')
if [ -n "$LEARNING_FILES" ]; then
  for LEARNING_FILE in $LEARNING_FILES; do
    if [ -f "$LEARNING_FILE" ]; then
      LEARNING_OK=1
      # Must reference an issue number
      if ! grep -qE '#[0-9]+|issue|Issue' "$LEARNING_FILE" 2>/dev/null; then
        echo -e "${YELLOW}[WARN] Learning capture missing issue reference: $LEARNING_FILE${NC}"
        echo "  Add a reference to the originating issue (e.g. #42)."
        LEARNING_OK=0
      fi
      # Must have a review/source link section
      if ! grep -qiE 'review|source|origin' "$LEARNING_FILE" 2>/dev/null; then
        echo -e "${YELLOW}[WARN] Learning capture missing review/source link: $LEARNING_FILE${NC}"
        echo "  Link back to the review artifact that makes this learning trustworthy."
        LEARNING_OK=0
      fi
      if [ $LEARNING_OK -eq 1 ]; then
        echo -e "${GREEN}[PASS] Learning capture structure valid: $LEARNING_FILE${NC}"
      fi
    fi
  done
fi

# ---------------------------------------------------------------
# Check 11: Approved review without learning capture (advisory)
# Warns when approving a review without a matching LEARNING file.
# ---------------------------------------------------------------
APPROVED_REVIEWS=$(git diff --cached --name-only | grep '^docs/artifacts/reviews/REVIEW-.*\.md$')
if [ -n "$APPROVED_REVIEWS" ]; then
  for REVIEW_FILE in $APPROVED_REVIEWS; do
    if [ -f "$REVIEW_FILE" ] && grep -qiE 'APPROVED|approved|Approved' "$REVIEW_FILE" 2>/dev/null; then
      # Extract issue number from review filename (REVIEW-<issue>.md)
      ISSUE_NUM=$(echo "$REVIEW_FILE" | grep -oE '[0-9]+' | head -1)
      if [ -n "$ISSUE_NUM" ]; then
        LEARNING_PATH="docs/artifacts/learnings/LEARNING-${ISSUE_NUM}.md"
        if [ ! -f "$LEARNING_PATH" ]; then
          echo -e "${YELLOW}[WARN] Approved review staged without Compound Capture: $REVIEW_FILE${NC}"
          echo "  Resolve Compound Capture before declaring work Done:"
          echo "    Mandatory: create $LEARNING_PATH"
          echo "    Skip: record rationale in the issue close comment"
          echo "  See docs/WORKFLOW.md for the full Compound Capture contract."
        else
          echo -e "${GREEN}[PASS] Learning capture exists for approved review: $LEARNING_PATH${NC}"
        fi
      fi
    fi
  done
fi

# ---------------------------------------------------------------
# Check 12: Deliverable structure validation (pipeline phase compliance)
# Validates key artifacts have required sections proving phases were completed.
# PRD: must have Problem Statement / Goals / Requirements sections.
# ADR: must evaluate at least 3 options.
# UX spec: must have a corresponding prototype file.
# ---------------------------------------------------------------

# PRD structure check
PRD_FILES=$(git diff --cached --name-only | grep '^docs/artifacts/prd/PRD-.*\.md$')
if [ -n "$PRD_FILES" ]; then
  for PRD in $PRD_FILES; do
    if [ -f "$PRD" ]; then
      if ! grep -qiE '##[[:space:]]*(Problem Statement|Goals|Requirements|Acceptance Criteria|User Stories)' "$PRD" 2>/dev/null; then
        echo -e "${YELLOW}[WARN] PRD missing required sections: $PRD${NC}"
        echo "  PRD MUST include: Problem Statement, Goals, Requirements, or Acceptance Criteria."
        echo "  Complete the Research phase before writing the PRD."
      else
        echo -e "${GREEN}[PASS] PRD structure valid: $PRD${NC}"
      fi
    fi
  done
fi

# ADR structure check -- must evaluate at least 3 options
ADR_FILES=$(git diff --cached --name-only | grep '^docs/artifacts/adr/ADR-.*\.md$')
if [ -n "$ADR_FILES" ]; then
  for ADR in $ADR_FILES; do
    if [ -f "$ADR" ]; then
      OPTION_COUNT=$(grep -ciE '###[[:space:]]*Option[[:space:]]+[0-9]|##[[:space:]]*Option[[:space:]]*[0-9]' "$ADR" 2>/dev/null)
      if [ -z "$OPTION_COUNT" ] || [ "$OPTION_COUNT" -lt 3 ] 2>/dev/null; then
        echo -e "${YELLOW}[WARN] ADR evaluates fewer than 3 options: $ADR${NC}"
        echo "  Architect MUST evaluate at least 3 options. Complete the research phase first."
      else
        echo -e "${GREEN}[PASS] ADR evaluates $OPTION_COUNT options: $ADR${NC}"
      fi
    fi
  done
fi

# UX spec check -- must have a corresponding prototype file
UX_SPEC_FILES=$(git diff --cached --name-only | grep '^docs/ux/UX-.*\.md$')
if [ -n "$UX_SPEC_FILES" ]; then
  for UX_SPEC in $UX_SPEC_FILES; do
    if [ -f "$UX_SPEC" ]; then
      ISSUE_NUM=$(echo "$UX_SPEC" | grep -oE '[0-9]+' | head -1)
      if [ -n "$ISSUE_NUM" ]; then
        PROTO_EXISTS=$(find docs/ux/prototypes -name "*${ISSUE_NUM}*" 2>/dev/null | head -1)
        if [ -z "$PROTO_EXISTS" ]; then
          echo -e "${YELLOW}[WARN] UX spec staged without a matching prototype: $UX_SPEC${NC}"
          echo "  UX Designer MUST create HTML/CSS prototypes at docs/ux/prototypes/ before handoff."
          echo "  Complete the HTML/CSS Prototypes phase before committing the UX spec."
        else
          echo -e "${GREEN}[PASS] UX prototype exists for spec: $PROTO_EXISTS${NC}"
        fi
      fi
    fi
  done
fi

if [ $FAILED -eq 1 ]; then
 echo -e "${RED}[FAIL] Pre-commit checks FAILED${NC}"
 exit 1
else
 echo -e "${GREEN}[PASS] Security checks passed${NC}"
 exit 0
fi
